{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "rnstartiosdk"
  ],
  "ios": {
    "iosModuleName": "RNStartIoSdk"
  },
  "android": {
    "androidNamespace": [
      "rnstartiosdk"
    ],
    "androidCxxLibName": "RNStartIoSdk"
  },
  "autolinking": {
    "RNStartIoSdk": {
      "android": {
        "language": "kotlin",
        "implementationClassName": "RNStartIoSdk"
      },
      "ios": {
        "language": "swift",
        "implementationClassName": "RNStartIoSdk"
      }
    },
    "RNStartIoBanner": {
      "android": {
        "language": "kotlin",
        "implementationClassName": "RNStartIoBanner"
      },
      "ios": {
        "language": "swift",
        "implementationClassName": "RNStartIoBanner"
      }
    },
    "RNStartIoNativeAd": {
      "android": {
        "language": "kotlin",
        "implementationClassName": "RNStartIoNativeAd"
      },
      "ios": {
        "language": "swift",
        "implementationClassName": "RNStartIoNativeAd"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}